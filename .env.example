# ── LLM ──────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── External APIs ─────────────────────────────────
# Open-Meteo is free and requires no API key.
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1

# ── Alerting – Email (SMTP) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ── Alerting – SMS ────────────────────────────────
# SMS alerts are currently disabled (no free provider configured).
# To enable, integrate a free-tier provider (e.g. AWS SNS) and
# update backend/agents/alerting/channels/sms_channel.py accordingly.

# ── App ───────────────────────────────────────────
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:5173

# ── Storage ───────────────────────────────────────
STORAGE_PATH=./data
