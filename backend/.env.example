# ─────────────────────────────────────────────────────────────────────────────
# FloodSense AI – Environment Variables
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (Required) ────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── External APIs (Optional) ──────────────────────────────────────────────────
# Open-Meteo is fully free and requires no API key (base URL already set).
OPENMETEO_BASE_URL=https://api.open-meteo.com/v1

# ── Email Alerts (SMTP) ───────────────────────────────────────────────────────
# For Gmail: enable "App Passwords" under your Google Account security settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=FloodSense AI <your_email@gmail.com>

# ── SMS Alerts ───────────────────────────────────────────────────────────────
# SMS is currently disabled (no free provider configured).
# To enable SMS, integrate a free-tier provider such as AWS SNS and add
# the relevant credentials here, then update sms_channel.py accordingly.

# ── Push Notifications (Firebase Cloud Messaging) ─────────────────────────────
# Download your service account JSON from Firebase Console → Project Settings
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json

# ── Webhook Alerts ────────────────────────────────────────────────────────────
# e.g. Slack incoming webhook URL, or your own dashboard endpoint
WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
WEBHOOK_AUTH_TOKEN=

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR

# Comma-separated list of allowed CORS origins (your React frontend URL)
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Directory for uploaded files and session artifacts
STORAGE_PATH=./data

# Archive sessions older than this many hours on shutdown
SESSION_MAX_AGE_HOURS=24
